# ── frontend/.env.example ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is in .gitignore and must NEVER be committed.
# All REACT_APP_ variables are embedded in the frontend bundle at build time.

# ── Firebase project config ───────────────────────────────────────────────────
# Find these in Firebase Console → Project Settings → General → Your apps
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# ── Cloud Functions base URL ───────────────────────────────────────────────────
# Production: https://{region}-{project-id}.cloudfunctions.net
# Local dev: http://localhost:5001/{project-id}/us-central1
REACT_APP_FUNCTIONS_BASE_URL=

# ── OAuth client IDs (public — safe to include in frontend bundle) ────────────
REACT_APP_GOOGLE_CLIENT_ID=
REACT_APP_MS_CLIENT_ID=

# ── Local development ─────────────────────────────────────────────────────────
# Set to true to connect to Firebase Emulator Suite instead of production
REACT_APP_USE_EMULATORS=false
