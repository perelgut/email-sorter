# ── functions/.env.example ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is in .gitignore and must NEVER be committed.
# In production, these are set as Firebase environment secrets via:
#   firebase functions:secrets:set ANTHROPIC_API_KEY

# ── Anthropic Claude API ───────────────────────────────────────────────────────
# Your existing Anthropic API key.
# NEVER expose this in frontend code or commit it to the repository.
ANTHROPIC_API_KEY=

# ── Credential encryption ─────────────────────────────────────────────────────
# 32-character random string used for AES-256-GCM encryption of IMAP passwords.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
ENCRYPTION_SECRET=

# ── Firebase project ──────────────────────────────────────────────────────────
# Used by Firebase Admin SDK — automatically available in deployed Functions.
# Required locally when running outside the emulator.
FIREBASE_PROJECT_ID=
